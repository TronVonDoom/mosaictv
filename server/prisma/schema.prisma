generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A library groups one or more root folders to scan (e.g. movies + movies_4k).
model Library {
  id        Int             @id @default(autoincrement())
  name      String
  // Legacy single path (pre-multi-folder). Kept nullable only so existing rows
  // can be backfilled into LibraryFolder on startup; new code ignores it.
  path      String?
  kind      String // "tv" | "movie" | "other"
  createdAt DateTime        @default(now())
  folders   LibraryFolder[]
  items     MediaItem[]
  shows     Show[]
}

// Simple key/value store (e.g. the TMDB API key).
model Setting {
  key   String @id
  value String
}

// An uploaded non-logo media asset (ambient audio, custom filler video),
// managed on the Media page. Files live under the data dir /assets.
model Asset {
  id        Int      @id @default(autoincrement())
  name      String
  kind      String // "audio" | "filler"
  filename  String // stored under the data dir /assets
  mime      String
  sizeBytes Int?
  createdAt DateTime @default(now())
}

// An uploaded logo/watermark image, reusable across channels and blocks.
model Logo {
  id        Int         @id @default(autoincrement())
  name      String
  filename  String // stored under the data dir /logos
  mime      String
  // Per-logo watermark settings (JSON WatermarkConfig). Null = inherit the
  // global default watermark. Lets each logo carry its own mode/size/position/
  // opacity/timing and the constrain-to-media flag.
  watermark String?
  createdAt DateTime    @default(now())
  channels  Channel[]
  blocks    TimeBlock[]
  collections Collection[]
}

// Show-level metadata (one row per distinct show title in a TV library).
model Show {
  id               Int      @id @default(autoincrement())
  library          Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId        Int
  title            String
  year             Int?
  tmdbId           Int?
  overview         String?
  genres           String? // comma-separated
  rating           Float?
  tmdbPosterPath   String? // TMDB path like "/abc.jpg"
  tmdbBackdropPath String?
  updatedAt        DateTime @updatedAt
  seasons          Season[]

  @@unique([libraryId, title])
}

model Season {
  id             Int     @id @default(autoincrement())
  show           Show    @relation(fields: [showId], references: [id], onDelete: Cascade)
  showId         Int
  number         Int
  tmdbPosterPath String?
  overview       String?

  @@unique([showId, number])
}

// A named set of media used to program channels — the "branded unit" (e.g. a
// sub-brand like "Nick Jr."). Owned by one channel; carries its own logo (and,
// later, filler). Members are hand-picked shows and movies; the optional smart
// filter adds a query-based set (unioned in).
model Collection {
  id           Int              @id @default(autoincrement())
  name         String
  // Owning channel (null = orphan/unassigned). Cascade-deletes with the channel.
  channel      Channel?         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId    Int?
  // The collection's own on-screen logo (falls back to the channel logo).
  logo         Logo?            @relation(fields: [logoId], references: [id], onDelete: SetNull)
  logoId       Int?
  // Optional smart filter (advanced).
  libraryId    Int?
  filterType   String? // "movie" | "episode" | "other"
  filterShow   String? // exact show title (legacy; prefer members)
  filterSearch String? // title/show contains
  filterGenre  String? // genre contains
  createdAt    DateTime         @default(now())
  items        CollectionItem[]
  rotationItems RotationItem[]
  timeBlocks   TimeBlock[]

  @@index([channelId])
}

// A hand-picked member of a collection: a whole show, or a single movie.
model CollectionItem {
  id           Int        @id @default(autoincrement())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId Int
  kind         String // "show" | "movie"
  showTitle    String? // for kind "show"
  libraryId    Int? // for kind "show" (which library the show is in)
  mediaItemId  Int? // for kind "movie"
  label        String? // denormalized display name
  order        Int        @default(0)

  @@index([collectionId])
}

// A virtual TV channel: a container for its collections, a rotation (24/7
// default) + optional time blocks. `number` is optional — a channel with no
// number is a draft (not exposed in the M3U/guide/stream until it gets one).
model Channel {
  id            Int            @id @default(autoincrement())
  number        Int?           @unique
  name          String
  group         String?
  logoUrl       String? // legacy free-form logo URL (fallback)
  logo          Logo?          @relation(fields: [logoId], references: [id], onDelete: SetNull)
  logoId        Int?
  createdAt     DateTime       @default(now())
  // Playout build state (see playout engine).
  playoutAnchor DateTime?
  playoutCursor DateTime?
  playoutState  String? // JSON { rotationIndex, positions }
  collections   Collection[]
  rotationItems RotationItem[]
  timeBlocks    TimeBlock[]
  playout       PlayoutItem[]
}

// One step in a channel's 24/7 rotation.
model RotationItem {
  id            Int        @id @default(autoincrement())
  channel       Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId     Int
  order         Int
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  Int
  playbackOrder String     @default("chronological") // "chronological" | "shuffle"
  mode          String     @default("one") // "one" | "multiple"
  count         Int        @default(1)

  @@index([channelId])
}

// A day/time block that overrides the rotation while active.
model TimeBlock {
  id            Int        @id @default(autoincrement())
  channel       Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId     Int
  days          String // CSV of day numbers, Sun=0 .. Sat=6, e.g. "1,2,3,4,5"
  startMinute   Int // minutes from local midnight
  endMinute     Int
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  Int
  playbackOrder String     @default("chronological")
  logoUrl       String? // legacy free-form logo URL (fallback)
  logo          Logo?      @relation(fields: [logoId], references: [id], onDelete: SetNull)
  logoId        Int?
  fillerMode    String     @default("none") // "none" | "between" | "end"

  @@index([channelId])
}

// A single scheduled program on a channel's timeline.
model PlayoutItem {
  id          Int        @id @default(autoincrement())
  channel     Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId   Int
  mediaItem   MediaItem? @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  mediaItemId Int? // null for filler
  kind        String     @default("program") // "program" | "filler"
  title       String? // label for filler / EPG
  startTime   DateTime
  stopTime    DateTime

  @@index([channelId, startTime])
}

// One root folder belonging to a library.
model LibraryFolder {
  id        Int      @id @default(autoincrement())
  library   Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId Int
  path      String   @unique
  createdAt DateTime @default(now())

  @@index([libraryId])
}

// A single video file discovered by the scanner.
model MediaItem {
  id          Int      @id @default(autoincrement())
  library     Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  libraryId   Int
  path        String   @unique
  type        String // "movie" | "episode" | "other"
  title       String
  showTitle   String?
  season      Int?
  episode     Int?
  year        Int?
  durationSec Float?
  width       Int?
  height      Int?
  videoCodec  String?
  audioCodec  String?
  container   String?
  sizeBytes   Float? // Float (not Int) — file sizes exceed 32-bit; avoids BigInt JSON pain
  mtimeMs     Float? // used to skip re-probing unchanged files
  // Local artwork on disk (Plex/Kodi/Jellyfin naming), served via /api/artwork.
  posterPath       String? // this item's own art (movie poster / episode thumb)
  showPosterPath   String? // show-level art (shared by all episodes of a show)
  seasonPosterPath String? // season-level art (shared by a season's episodes)
  // TMDB metadata (mainly for movies; episodes/other may stay null).
  tmdbId           Int?
  overview         String?
  genres           String? // comma-separated
  rating           Float?
  tmdbPosterPath   String?
  tmdbBackdropPath String?
  missing     Boolean  @default(false)
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt
  playouts    PlayoutItem[]

  @@index([libraryId])
  @@index([type])
  @@index([showTitle])
}
